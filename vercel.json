{
  "buildCommand": "bun run build",
  "installCommand": "bun install",
  "framework": null,
  "outputDirectory": "dist",
  "routes": [
    { "src": "/api/zite/(.*)",  "dest": "/api/zite-proxy?p=$1"  },
    { "src": "/api/floot/(.*)", "dest": "/api/floot-proxy?p=$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
